<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:background="@drawable/bg"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context="com.intruderselfie.geolocation.hiddenpic.thirdeye.MainCode.OnBoardingScreens.SmSOnBoardActivity">
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/_10sdp"
        android:layout_marginEnd="@dimen/_10sdp"
        android:text="Skip"
        android:textColor="@color/white"
        android:textSize="@dimen/_14sdp"
        android:id="@+id/skip"
        android:gravity="end"
        android:layout_gravity="end"
        android:fontFamily="@font/quicksand_bold"/>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginTop="@dimen/_50sdp">
        <ImageView
            android:layout_width="@dimen/_120sdp"
            android:layout_height="@dimen/_120sdp"
            android:src="@drawable/sms_on"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="@dimen/_30sdp"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_5sdp"
            android:fontFamily="@font/quicksand_bold"
            android:text="SMS Alerts"
            android:textColor="@color/white"
            android:textSize="@dimen/_24sdp"
            />
        <View
            android:layout_width="match_parent"
            android:layout_height="@dimen/_60sdp"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/quicksand_light"
            android:text="Instantly receive SMS alerts containing\nboth the intruder's location and the\ncaptured selfie, enabling you\nto stay informed."
            android:textColor="@color/white"
            android:textAlignment="center"
            android:layout_marginTop="@dimen/_5sdp"
            android:textSize="@dimen/_14sdp"
            />


        <androidx.cardview.widget.CardView
            android:id="@+id/sms_next"
            android:layout_width="@dimen/_160sdp"
            android:layout_height="@dimen/_42sdp"
            app:cardCornerRadius="@dimen/_220sdp"
            app:cardMaxElevation="@dimen/_10sdp"
            android:elevation="@dimen/_10sdp"
            android:layout_marginTop="@dimen/_45sdp"
            app:cardElevation="@dimen/_10sdp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:fontFamily="@font/quicksand_bold"
                android:gravity="center"
                android:text="Next"
                android:textColor="@color/black"
                android:textSize="@dimen/_14sdp" />
        </androidx.cardview.widget.CardView>



        <ImageView
            android:layout_width="@dimen/_50sdp"
            android:layout_height="@dimen/_50sdp"
            android:layout_marginTop="@dimen/_5sdp"
            android:src="@drawable/dots_3"/>

    </LinearLayout>
</LinearLayout>