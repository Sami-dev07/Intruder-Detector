<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    >

   <LinearLayout
       android:layout_width="match_parent"
       android:layout_height="match_parent"
       android:orientation="vertical"
       android:gravity="center"
       android:layout_margin="@dimen/_20sdp">
       <ImageView
           android:layout_width="@dimen/_50sdp"
           android:layout_height="@dimen/_50sdp"
           android:src="@drawable/icon02"/>

       <TextView
           android:layout_width="match_parent"
           android:layout_height="wrap_content"
           android:text="Background Location Permission"
           android:textSize="@dimen/_16sdp"
           android:textAlignment="center"
           android:fontFamily="@font/quicksand_bold"
           android:layout_marginTop="@dimen/_10sdp"

           />

       <TextView
           android:layout_width="match_parent"
           android:layout_margin="@dimen/_10sdp"
           android:layout_height="wrap_content"
           android:text="Granting background location permission is one of the core functionalities which  allows the app to provide location-based services to user in case of mobile theft and unauthorized access, even when the app is not actively in use ."
           android:textColor="@color/black"
           android:textSize="@dimen/_14sdp"
           android:textAlignment="center"
           android:fontFamily="@font/quicksand_medium"/>

       <TextView
           android:layout_width="match_parent"
           android:layout_margin="@dimen/_10sdp"
           android:layout_height="wrap_content"
           android:text="If you are agree to allow the background location permission then you can allow it from settings. 'Allow all the time'"
           android:textColor="@color/black"
           android:textSize="@dimen/_14sdp"
           android:textAlignment="center"
           android:fontFamily="@font/quicksand_medium"/>

       <LinearLayout
           android:layout_width="match_parent"
           android:layout_height="wrap_content"
           android:gravity="end"
           android:layout_marginTop="@dimen/_15sdp"
           android:orientation="horizontal">
           <androidx.appcompat.widget.AppCompatButton
               android:id="@+id/deny"
               android:layout_width="@dimen/_80sdp"
               android:layout_height="@dimen/_35sdp"
               android:text="deny"
               android:layout_marginHorizontal="@dimen/_5sdp"
               android:textColor="@color/white"
               android:background="@drawable/red_round"/>
           <androidx.appcompat.widget.AppCompatButton
               android:id="@+id/allow"
               android:layout_width="@dimen/_80sdp"
               android:layout_height="@dimen/_35sdp"
               android:text="Allow"
               android:layout_marginHorizontal="@dimen/_5sdp"
               android:textColor="@color/white"
               android:background="@drawable/green_round"

               />
       </LinearLayout>
   </LinearLayout>


</LinearLayout>